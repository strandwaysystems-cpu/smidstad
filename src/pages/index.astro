---
import Base from '../layouts/Base.astro';
---
<Base>

<!-- NAV -->
<nav id="nav">
  <a href="/" class="nav-logo">
    <svg class="logo-mark" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="32" height="32" rx="9" fill="#ccf24d"/>
      <path d="M11 21.5C11 22.5 12.2 23.5 14.2 23.5C16.4 23.5 17.6 22.3 17.6 20.7C17.6 19.1 16.5 18.4 14.6 17.9L13.6 17.6C12.8 17.4 12.4 17.1 12.4 16.5C12.4 15.9 12.9 15.5 13.7 15.5C14.5 15.5 15 15.9 15.1 16.6H17.4C17.3 14.9 16 13.7 13.8 13.7C11.7 13.7 10.3 14.9 10.3 16.6C10.3 18.1 11.3 18.9 13 19.3L14 19.6C15 19.8 15.4 20.1 15.4 20.7C15.4 21.3 14.9 21.7 14.1 21.7C13.2 21.7 12.6 21.3 12.5 20.5L11 21.5Z" fill="#161614"/>
      <path d="M19.5 9L22.5 12L19.5 15" stroke="#161614" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    smidstad
  </a>
  <ul class="nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#process">Process</a></li>
    <li><a href="#pricing">Pricing</a></li>
    <li><a href="#contact" class="nav-cta">Start a project</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg-circle"></div>
  <div class="hero-content">
    <div class="hero-left">
      <div class="hero-badge">
        <div class="pulse"></div>
        Now accepting projects
      </div>
      <h1>Digital craft,<br><em>forged</em> smarter.</h1>
      <p class="hero-sub">Websites, portfolios, landing pages, and ghostwritten content — delivered at AI speed with human precision.</p>
    </div>
    <div class="hero-right">
      <div class="hero-cta-group">
        <a href="#contact" class="btn-primary">Get your mockup →</a>
        <a href="#services" class="btn-ghost">See the work</a>
      </div>
      <div class="hero-stat-row">
        <div class="hero-stat">
          <span class="hero-stat-num">3–7</span>
          <span class="hero-stat-label">Days to delivery</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-num">$297</span>
          <span class="hero-stat-label">Starting price</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-num">$99</span>
          <span class="hero-stat-label">Paid mockup</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- MARQUEE -->
<div class="marquee-section" aria-hidden="true">
  <div class="marquee-track">
    <span class="marquee-item">Portfolio Sites</span>
    <span class="marquee-item">Landing Pages</span>
    <span class="marquee-item">LinkedIn Ghostwriting</span>
    <span class="marquee-item">Brand Websites</span>
    <span class="marquee-item">Content Kits</span>
    <span class="marquee-item">Lead Generation</span>
    <span class="marquee-item">Portfolio Sites</span>
    <span class="marquee-item">Landing Pages</span>
    <span class="marquee-item">LinkedIn Ghostwriting</span>
    <span class="marquee-item">Brand Websites</span>
    <span class="marquee-item">Content Kits</span>
    <span class="marquee-item">Lead Generation</span>
  </div>
</div>

<!-- SERVICES -->
<section id="services" class="forge-section">
  <div class="section-inner">
    <div class="forge-header reveal">
      <div>
        <div class="section-label">What we forge</div>
        <h2>Built for creators.<br>Scaled for business.</h2>
      </div>
      <p>Every deliverable is built to a spec, not a template. Fast, intentional, and designed to convert from day one.</p>
    </div>
    <div class="services-grid reveal">
      <div class="service-card">
        <div class="service-icon green">
          <svg viewBox="0 0 24 24" fill="none" stroke="#3b6d11" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v8M8 12h8"/></svg>
        </div>
        <h3>Portfolio Sites</h3>
        <p>Stand-out personal sites for creators, coaches, and solopreneurs. Your brand, your voice, live fast.</p>
        <div class="service-price">$297 <span>one-time</span></div>
      </div>
      <div class="service-card">
        <div class="service-icon dark">
          <svg viewBox="0 0 24 24" fill="none" stroke="#ccf24d" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/></svg>
        </div>
        <h3>Landing Pages</h3>
        <p>High-converting single pages for offers, launches, lead magnets, and products. Built to sell.</p>
        <div class="service-price">$397 <span>one-time</span></div>
      </div>
      <div class="service-card">
        <div class="service-icon warm">
          <svg viewBox="0 0 24 24" fill="none" stroke="#854f0b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
        </div>
        <h3>Ghostwriting</h3>
        <p>LinkedIn posts, email sequences, and content kits. Your ideas, polished and published consistently.</p>
        <div class="service-price">$997 <span>/ month</span></div>
      </div>
      <div class="service-card">
        <div class="service-icon cool">
          <svg viewBox="0 0 24 24" fill="none" stroke="#185fa5" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-4"/></svg>
        </div>
        <h3>Business Sites</h3>
        <p>Full service websites for SMBs. Professional presence that drives real leads and real revenue.</p>
        <div class="service-price">$997 <span>one-time</span></div>
      </div>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section id="process" class="process-section">
  <div class="section-inner">
    <div class="section-label">How it works</div>
    <h2 class="reveal">From idea to live.<br>Painless and fast.</h2>
    <div class="process-steps">
      <div class="step reveal">
        <div class="step-num">01</div>
        <h3>Tell us your vision</h3>
        <p>Share your goals, existing brand, or a rough idea. We reply within a few hours — no long intake forms.</p>
        <span class="step-badge">Free consultation</span>
      </div>
      <div class="step reveal">
        <div class="step-num">02</div>
        <h3>Get a custom mockup</h3>
        <p>Pay $99 and we build a real preview of your site — not a wireframe. Credited toward your full build.</p>
        <span class="step-badge">$99 — credited on build</span>
      </div>
      <div class="step reveal">
        <div class="step-num">03</div>
        <h3>We deliver and launch</h3>
        <p>Full build, your domain, revisions included. Live in 3–7 days. You never touch a line of code.</p>
        <span class="step-badge">3–7 day turnaround</span>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing" class="pricing-section">
  <div class="section-inner">
    <div class="pricing-header reveal">
      <div>
        <div class="section-label">Pricing</div>
        <h2>Simple.<br>No surprises.</h2>
      </div>
      <p class="pricing-note">All projects include one round of revisions and a 14-day support window post-launch.</p>
    </div>
    <div class="pricing-grid">
      <div class="pricing-card reveal">
        <div class="pricing-card-label">For Creators</div>
        <div class="pricing-card-price">$297+</div>
        <div class="pricing-card-desc">Portfolio sites, landing pages, and content kits for solopreneurs and builders.</div>
        <ul class="pricing-features">
          <li><div class="feat-check"><svg viewBox="0 0 24 24" fill="none" stroke="#161614" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 6"/></svg></div> Portfolio or landing page</li>
          <li><div class="feat-check"><svg viewBox="0 0 24 24" fill="none" stroke="#161614" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 6"/></svg></div> Mobile responsive design</li>
          <li><div class="feat-check"><svg viewBox="0 0 24 24" fill="none" stroke="#161614" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 6"/></svg></div> Custom to your brand</li>
          <li><div class="feat-check"><svg viewBox="0 0 24 24" fill="none" stroke="#161614" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 6"/></svg></div> Delivered in 3–5 days</li>
          <li><div class="feat-check"><svg viewBox="0 0 24 24" fill="none" stroke="#161614" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 6"/></svg></div> One round of revisions</li>
        </ul>
        <a href="#contact" class="btn-card btn-card-dark">Get started</a>
      </div>
      <div class="pricing-card featured reveal">
        <div class="pricing-card-label">For Businesses</div>
        <div class="pricing-card-price" style="color:var(--ember)">$997+</div>
        <div class="pricing-card-desc">Full service websites, ghostwriting, and lead gen systems for serious operators.</div>
        <ul class="pricing-features">
          <li><div class="feat-check"><svg viewBox="0 0 24 24" fill="none" stroke="#161614" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 6"/></svg></div> 5-page professional website</li>
          <li><div class="feat-check"><svg viewBox="0 0 24 24" fill="none" stroke="#161614" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 6"/></svg></div> SEO-ready structure</li>
          <li><div class="feat-check"><svg viewBox="0 0 24 24" fill="none" stroke="#161614" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 6"/></svg></div> Contact &amp; lead capture forms</li>
          <li><div class="feat-check"><svg viewBox="0 0 24 24" fill="none" stroke="#161614" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 6"/></svg></div> Delivered in 5–7 days</li>
          <li><div class="feat-check"><svg viewBox="0 0 24 24" fill="none" stroke="#161614" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 6"/></svg></div> Ghostwriting available as add-on</li>
        </ul>
        <a href="#contact" class="btn-card btn-card-ember">Start a project</a>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <h2>Ready to get<br>forged?</h2>
  <p>Tell us your project and we'll send a tailored mockup idea within 24 hours.</p>
  <a href="#contact" class="btn-primary" style="margin:0 auto;display:inline-flex;background:var(--ink);color:var(--paper)">Get your mockup →</a>
</section>

<!-- CONTACT -->
<section id="contact" class="contact-section">
  <div class="contact-inner">
    <div class="section-label">Contact</div>
    <h2 class="reveal">Let's build<br>something great.</h2>
    <p class="reveal">Fill in the form and we'll get back to you within a few hours with next steps.</p>
    <form action="https://formsubmit.co/hello@smidstad.com" method="POST" class="reveal">
      <input type="hidden" name="_subject" value="New Smidstad Project Inquiry" />
      <input type="hidden" name="_captcha" value="false" />
      <div class="form-row">
        <div class="form-field">
          <label for="name">Your name</label>
          <input type="text" id="name" name="name" placeholder="Jane Smith" required />
        </div>
        <div class="form-field">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" placeholder="jane@email.com" required />
        </div>
      </div>
      <div class="form-field" style="margin-bottom:1rem">
        <label for="type">I need</label>
        <select id="type" name="project_type">
          <option value="">Select a service...</option>
          <option value="portfolio">Portfolio site ($297)</option>
          <option value="landing">Landing page ($397)</option>
          <option value="business">Business website ($997)</option>
          <option value="ghostwriting">Ghostwriting ($997/mo)</option>
          <option value="mockup">Paid mockup first ($99)</option>
          <option value="other">Not sure yet</option>
        </select>
      </div>
      <div class="form-field">
        <label for="message">Tell us about your project</label>
        <textarea id="message" name="message" rows="5" placeholder="What are you building? Who's it for? Any existing site or brand assets we should know about?" required></textarea>
      </div>
      <button type="submit" class="form-submit">Send message — let's build</button>
      <p class="form-fine">Or email directly: <a href="mailto:hello@smidstad.com">hello@smidstad.com</a></p>
    </form>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <a href="/" class="footer-logo">
    <svg class="logo-mark" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="32" height="32" rx="9" fill="#ccf24d"/>
      <path d="M11 21.5C11 22.5 12.2 23.5 14.2 23.5C16.4 23.5 17.6 22.3 17.6 20.7C17.6 19.1 16.5 18.4 14.6 17.9L13.6 17.6C12.8 17.4 12.4 17.1 12.4 16.5C12.4 15.9 12.9 15.5 13.7 15.5C14.5 15.5 15 15.9 15.1 16.6H17.4C17.3 14.9 16 13.7 13.8 13.7C11.7 13.7 10.3 14.9 10.3 16.6C10.3 18.1 11.3 18.9 13 19.3L14 19.6C15 19.8 15.4 20.1 15.4 20.7C15.4 21.3 14.9 21.7 14.1 21.7C13.2 21.7 12.6 21.3 12.5 20.5L11 21.5Z" fill="#161614"/>
      <path d="M19.5 9L22.5 12L19.5 15" stroke="#161614" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    smidstad
  </a>
  <p class="footer-copy">© 2026 Smidstad. AI speed, human craft.</p>
  <ul class="footer-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#process">Process</a></li>
    <li><a href="#pricing">Pricing</a></li>
    <li><a href="mailto:hello@smidstad.com">Contact</a></li>
  </ul>
</footer>

<script>
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  if (window.scrollY > 40) nav.classList.add('scrolled');
  else nav.classList.remove('scrolled');
});

const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver(entries => {
  entries.forEach((entry, i) => {
    if (entry.isIntersecting) {
      setTimeout(() => entry.target.classList.add('visible'), i * 80);
      observer.unobserve(entry.target);
    }
  });
}, {threshold: 0.1, rootMargin: '0px 0px -40px 0px'});
reveals.forEach(el => observer.observe(el));
</script>

</Base>
